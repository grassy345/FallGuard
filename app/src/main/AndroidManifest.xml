<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml — The App's ID Card -->
<!-- This file tells Android: -->
<!--   - What permissions the app needs -->
<!--   - What screens (Activities) the app has -->
<!--   - What background services run -->
<!--   - What happens when the phone boots up -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- === PERMISSIONS === -->
    <!-- Internet access — needed to talk to Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Run a persistent background service (the monitoring service) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Auto-start when phone boots up -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Show notifications (Android 13+ requires this) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Ask Android not to kill our app to save battery -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Keep CPU awake when processing alerts -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Show full-screen alarm over lock screen -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Override Do Not Disturb mode for emergency alerts -->
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />

    <!-- Display alarm over other apps (required on Android 10+ for reliable alarm display) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FallGuard">

        <!-- === LOGIN SCREEN (new launcher) === -->
        <!-- First screen when the app opens — must log in before monitoring -->
        <activity
            android:name=".LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.FallGuard.Alarm">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- === REGISTER SCREEN === -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.FallGuard.Alarm" />

        <!-- === MAIN SCREEN (dashboard) === -->
        <!-- Only accessible after login — starts the monitoring service -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- === ALARM SCREEN === -->
        <!-- Full-screen emergency alarm that shows over the lock screen -->
        <activity
            android:name=".AlarmActivity"
            android:exported="false"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:showWhenLocked="true"
            android:theme="@style/Theme.FallGuard.Alarm"
            android:launchMode="singleTop"
            android:excludeFromRecents="true" />

        <!-- === FULL HISTORY SCREEN === -->
        <activity
            android:name=".FullHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.FallGuard.DarkStatusBar" />

        <!-- === VIDEO PLAYER SCREEN === -->
        <activity
            android:name=".VideoPlayerActivity"
            android:exported="false"
            android:theme="@style/Theme.FallGuard.Alarm" />

        <!-- === SETTINGS SCREEN === -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.FallGuard.DarkStatusBar" />

        <!-- === BACKGROUND MONITORING SERVICE === -->
        <!-- This runs silently in the background, listening for fall alerts -->
        <service
            android:name=".FallDetectionService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Fall detection monitoring — listens to Firebase for elderly fall alerts" />
        </service>

        <!-- === BOOT RECEIVER === -->
        <!-- This automatically starts our monitoring service when the phone restarts -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
