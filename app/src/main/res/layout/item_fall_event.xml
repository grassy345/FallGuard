<?xml version="1.0" encoding="utf-8"?>
<!-- item_fall_event.xml — Single fall event card -->
<!-- Compact card: fall details LEFT, video thumbnail RIGHT -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Color strip on the far left (red for fall, amber for suspicious) -->
        <View
            android:id="@+id/colorStrip"
            android:layout_width="6dp"
            android:layout_height="match_parent"
            android:background="@color/alert_red" />

        <!-- Fall details — LEFT side -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Status label -->
            <TextView
                android:id="@+id/statusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fall Detected"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary" />

            <!-- Date and time -->
            <TextView
                android:id="@+id/dateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01/03/2026 03:01:37 PM"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

            <!-- Relative time -->
            <TextView
                android:id="@+id/relativeTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 hours ago"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <!-- Save button row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <!-- Acknowledged badge -->
                <TextView
                    android:id="@+id/acknowledgedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Acknowledged"
                    android:textSize="11sp"
                    android:textColor="@color/alert_green"
                    android:visibility="gone" />

                <!-- Save video button -->
                <ImageButton
                    android:id="@+id/saveButton"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/stat_sys_download"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Save video"
                    android:layout_marginStart="8dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- Video thumbnail — RIGHT side -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="12dp"
            android:layout_marginVertical="8dp">

            <!-- Thumbnail image (loaded by Glide) -->
            <ImageView
                android:id="@+id/videoThumbnail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Video clip"
                android:visibility="gone" />

            <!-- Play overlay icon (shown on top of thumbnail) -->
            <ImageView
                android:id="@+id/playOverlay"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_media_play"
                android:contentDescription="Play video"
                android:visibility="gone" />

            <!-- Processing placeholder (shown while clip_url is null) -->
            <LinearLayout
                android:id="@+id/processingPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#F0F0F0">

                <ProgressBar
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    style="?android:attr/progressBarStyleSmall" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Processing..."
                    android:textSize="10sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Error placeholder (shown when video link is dead) -->
            <LinearLayout
                android:id="@+id/errorPlaceholder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:background="#FFF0F0"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="❌"
                    android:textSize="20sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Unavailable"
                    android:textSize="10sp"
                    android:textColor="@color/alert_red"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
