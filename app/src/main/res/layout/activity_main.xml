<?xml version="1.0" encoding="utf-8"?>
<!-- activity_main.xml — The Main Dashboard Screen -->
<!-- Shows monitoring status, logged-in user info, and logout button -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@color/background">

    <!-- App name -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Logged in as email -->
    <TextView
        android:id="@+id/userEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Logged in as: ..."
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="32dp" />

    <!-- Status text — updated by MainActivity.kt -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Starting monitoring service..."
        android:textSize="18sp"
        android:textColor="@color/text_primary"
        android:textAlignment="center"
        android:lineSpacingExtra="6dp"
        android:layout_marginBottom="48dp" />

    <!-- Logout button -->
    <Button
        android:id="@+id/logoutButton"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="LOG OUT"
        android:textSize="16sp"
        android:backgroundTint="@color/alert_red"
        android:textColor="@color/white" />

</LinearLayout>
