<?xml version="1.0" encoding="utf-8"?>
<!-- themes.xml — The app's visual theme -->
<!-- This tells Android: "Use Material Design with our deep blue color scheme" -->
<resources>
    <style name="Theme.FallGuard" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Status bar color (top bar of the phone) -->
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>
</resources>
